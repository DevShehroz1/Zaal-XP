{{ 'collection-1.css' | asset_url | stylesheet_tag }}

{% liquid
  case section.settings.image_ratio
    when 'portrait'
      assign aspect_ratio = '3/4'
    when 'tall'
      assign aspect_ratio = '2/3'
    when 'square'
      assign aspect_ratio = '1/1'
  endcase
%}

<div
  class="collection-1-section color-{{ section.settings.color_scheme }}"
  style="
    --collection-1-padding-top: {{ section.settings.padding_top }}px;
    --collection-1-padding-bottom: {{ section.settings.padding_bottom }}px;
    --collection-1-columns: {{ section.settings.columns_desktop }};
    --collection-1-gap: {{ section.settings.gap }}px;
    --collection-1-aspect-ratio: {{ aspect_ratio }};
  "
>
  <div class="collection-1__container section--{{ section.settings.section_width }}">
    {% if section.settings.heading != blank or section.settings.subheading != blank %}
      <div class="collection-1__header" style="text-align: {{ section.settings.heading_alignment }};">
        {% if section.settings.heading != blank %}
          <h2 class="collection-1__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="collection-1__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    <div class="collection-1__grid-wrapper" data-collection1-carousel>
      <div class="collection-1__grid" data-collection1-track>
        {% for block in section.blocks %}
          {% assign collection = block.settings.collection %}
          <a
            class="collection-1__card"
            href="{{ collection.url | default: '#' }}"
            {{ block.shopify_attributes }}
          >
            <div class="collection-1__image-wrapper">
              {% if block.settings.custom_image != blank %}
                {{
                  block.settings.custom_image
                  | image_url: width: 800
                  | image_tag:
                    class: 'collection-1__image',
                    loading: 'lazy',
                    widths: '400,600,800',
                    sizes: '(max-width: 749px) 50vw, 25vw'
                }}
              {% elsif collection != blank and collection.image != blank %}
                {{
                  collection.image
                  | image_url: width: 800
                  | image_tag:
                    class: 'collection-1__image',
                    loading: 'lazy',
                    widths: '400,600,800',
                    sizes: '(max-width: 749px) 50vw, 25vw'
                }}
              {% else %}
                {{ 'collection-' | append: forloop.index | placeholder_svg_tag: 'collection-1__placeholder' }}
              {% endif %}
            </div>

            <div class="collection-1__card-info">
              <span class="collection-1__card-title">
                {{ collection.title | default: block.settings.title | default: 'Collection' }}
              </span>
              <span class="collection-1__card-arrow">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="none" width="24" height="24">
                  <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4.25 10h11.5m0 0-4-4m4 4-4 4"/>
                </svg>
              </span>
            </div>
          </a>
        {% endfor %}
      </div>

      <button class="collection-1__arrow collection-1__arrow--prev" data-collection1-prev aria-label="Previous">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
      </button>
      <button class="collection-1__arrow collection-1__arrow--next" data-collection1-next aria-label="Next">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
      </button>
    </div>
  </div>
</div>

<script>
  (function() {
    document.querySelectorAll('[data-collection1-carousel]').forEach(function(wrapper) {
      var track = wrapper.querySelector('[data-collection1-track]');
      var prevBtn = wrapper.querySelector('[data-collection1-prev]');
      var nextBtn = wrapper.querySelector('[data-collection1-next]');
      if (!track || !prevBtn || !nextBtn) return;

      function getScrollAmount() {
        var card = track.querySelector('.collection-1__card');
        if (!card) return 300;
        return card.offsetWidth + parseInt(getComputedStyle(track).gap || '16', 10);
      }

      function updateArrows() {
        prevBtn.disabled = track.scrollLeft <= 5;
        nextBtn.disabled = track.scrollLeft + track.clientWidth >= track.scrollWidth - 5;
      }

      prevBtn.addEventListener('click', function() {
        track.scrollBy({ left: -getScrollAmount(), behavior: 'smooth' });
      });

      nextBtn.addEventListener('click', function() {
        track.scrollBy({ left: getScrollAmount(), behavior: 'smooth' });
      });

      track.addEventListener('scroll', updateArrows);
      updateArrows();
      window.addEventListener('resize', updateArrows);
    });
  })();
</script>

{% schema %}
{
  "name": "Collection 1",
  "class": "collection-1-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Explore Trending Categories"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore Our Most Loved Pieces!"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Section layout"
    },
    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        { "value": "page-width", "label": "Page width" },
        { "value": "full-width", "label": "Full width" }
      ],
      "default": "page-width"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Card settings"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "portrait", "label": "Portrait (3:4)" },
        { "value": "tall", "label": "Tall (2:3)" },
        { "value": "square", "label": "Square (1:1)" }
      ],
      "default": "tall"
    },
    {
      "type": "range",
      "id": "columns_desktop",
      "label": "Columns on desktop",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between cards",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "collection_block",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title (optional)",
          "info": "Overrides collection title if set"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image (optional)",
          "info": "Overrides collection image if set"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Collection 1",
      "category": "Collections",
      "blocks": [
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" },
        { "type": "collection_block" }
      ]
    }
  ]
}
{% endschema %}
