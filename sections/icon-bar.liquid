{{ 'icon-bar.css' | asset_url | stylesheet_tag }}

<div
  class="icon-bar"
  style="
    --ib-padding-top: {{ section.settings.padding_top }}px;
    --ib-padding-bottom: {{ section.settings.padding_bottom }}px;
    --ib-bg: {{ section.settings.background_color }};
    --ib-text-color: {{ section.settings.text_color }};
    --ib-divider-color: {{ section.settings.divider_color }};
    --ib-icon-size: {{ section.settings.icon_size }}px;
  "
>
  <div class="icon-bar__container">
    {% for block in section.blocks %}
      {% unless forloop.first %}
        <div class="icon-bar__divider"></div>
      {% endunless %}

      <div class="icon-bar__item" {{ block.shopify_attributes }}>
        {% if block.settings.icon != blank %}
          <div class="icon-bar__icon">
            {{ block.settings.icon | image_url: width: 80 | image_tag: loading: 'lazy', widths: '40,60,80' }}
          </div>
        {% endif %}
        {% if block.settings.text != blank %}
          <span class="icon-bar__text">{{ block.settings.text }}</span>
        {% endif %}
      </div>
    {% endfor %}
  </div>
</div>

<script>
  (function() {
    if (window.innerWidth >= 750) return;
    var items = document.querySelectorAll('.icon-bar__item');
    if (items.length < 2) return;
    var current = 0;
    items[0].classList.add('icon-bar__item--active');
    setInterval(function() {
      items[current].classList.remove('icon-bar__item--active');
      items[current].classList.add('icon-bar__item--hidden');
      current = (current + 1) % items.length;
      items[current].classList.remove('icon-bar__item--hidden');
      items[current].classList.add('icon-bar__item--active');
    }, 3000);
  })();
</script>

{% schema %}
{
  "name": "Icon Bar",
  "class": "icon-bar-wrapper",
  "settings": [
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Divider color",
      "default": "#cccccc"
    },
    {
      "type": "header",
      "content": "Icon"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Icon size",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "item",
      "name": "Item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature text"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Icon Bar",
      "blocks": [
        { "type": "item", "settings": { "text": "Worldwide Shipping" } },
        { "type": "item", "settings": { "text": "No Questions Asked Exchange Policy" } },
        { "type": "item", "settings": { "text": "Safe Payment" } }
      ]
    }
  ],
  "max_blocks": 6
}
{% endschema %}
