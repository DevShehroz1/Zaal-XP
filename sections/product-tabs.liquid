{{ 'product-extras.css' | asset_url | stylesheet_tag }}

{% liquid
  assign has_description = false
  if product.description != blank and section.settings.show_description
    assign has_description = true
  endif
%}

<div
  class="product-tabs-section color-{{ section.settings.color_scheme }}"
  style="
    --pt-tabs: {{ section.settings.padding_top }}px;
    --pt-tabs-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="product-tabs__container">
    <div class="product-tabs__accordion">
      {% if has_description %}
        <details class="product-tabs__item">
          <summary class="product-tabs__trigger">
            <span>{{ section.settings.description_heading | default: 'Description' }}</span>
            <span class="product-tabs__icon">+</span>
          </summary>
          <div class="product-tabs__content">
            {{ product.description }}
          </div>
        </details>
      {% endif %}

      {% for block in section.blocks %}
        <details class="product-tabs__item" {{ block.shopify_attributes }}>
          <summary class="product-tabs__trigger">
            <span>{{ block.settings.heading }}</span>
            <span class="product-tabs__icon">+</span>
          </summary>
          <div class="product-tabs__content">
            {{ block.settings.content }}
          </div>
        </details>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Product Tabs",
  "class": "product-tabs-wrapper",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show product description tab",
      "default": true
    },
    {
      "type": "text",
      "id": "description_heading",
      "label": "Description tab heading",
      "default": "Description"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "tab",
      "name": "Tab",
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Tab heading",
          "default": "Material & Fit"
        },
        {
          "type": "richtext",
          "id": "content",
          "label": "Tab content",
          "default": "<p>Add your content here.</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Tabs",
      "category": "Products",
      "blocks": [
        { "type": "tab", "settings": { "heading": "Material & Fit" } },
        { "type": "tab", "settings": { "heading": "Design Philosophy" } },
        { "type": "tab", "settings": { "heading": "Care Instruction" } }
      ]
    }
  ],
  "templates": ["product"]
}
{% endschema %}
