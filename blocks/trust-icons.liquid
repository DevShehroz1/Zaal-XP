{{ 'product-extras.css' | asset_url | stylesheet_tag }}

<div class="product-trust-icons" {{ block.shopify_attributes }}>
  <div class="product-trust-icon">
    <svg class="product-trust-icon__svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
      <path d="M9 12l2 2 4-4"/>
    </svg>
    <span class="product-trust-icon__label">{{ block.settings.icon_1_label }}</span>
  </div>
  <div class="product-trust-icon">
    <svg class="product-trust-icon__svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <rect x="1" y="3" width="15" height="13" rx="1"/>
      <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"/>
      <circle cx="5.5" cy="18.5" r="2.5"/>
      <circle cx="18.5" cy="18.5" r="2.5"/>
    </svg>
    <span class="product-trust-icon__label">{{ block.settings.icon_2_label }}</span>
  </div>
  <div class="product-trust-icon">
    <svg class="product-trust-icon__svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/>
    </svg>
    <span class="product-trust-icon__label">{{ block.settings.icon_3_label }}</span>
  </div>
  <div class="product-trust-icon">
    <svg class="product-trust-icon__svg" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
      <path d="M3 2v6h6"/>
      <path d="M3 13a9 9 0 1 0 3-7.7L3 8"/>
    </svg>
    <span class="product-trust-icon__label">{{ block.settings.icon_4_label }}</span>
  </div>
</div>

{% schema %}
{
  "name": "Trust Icons",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "icon_1_label",
      "label": "Icon 1 label",
      "default": "Secure Ordering"
    },
    {
      "type": "text",
      "id": "icon_2_label",
      "label": "Icon 2 label",
      "default": "Fast Shipping"
    },
    {
      "type": "text",
      "id": "icon_3_label",
      "label": "Icon 3 label",
      "default": "Premium Quality"
    },
    {
      "type": "text",
      "id": "icon_4_label",
      "label": "Icon 4 label",
      "default": "Easy Returns"
    }
  ],
  "presets": [
    {
      "name": "Trust Icons"
    }
  ]
}
{% endschema %}
