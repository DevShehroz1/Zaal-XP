<details style="border-bottom:1px solid #ccc;width:100%;" {{ block.shopify_attributes }}>
  <summary style="display:flex;align-items:center;justify-content:space-between;width:100%;padding:20px 0;background:none;border:none;cursor:pointer;text-align:left;font-family:var(--font-heading--family,serif);font-size:clamp(18px,2vw,24px);font-weight:400;color:var(--color-foreground,#1a1a1a);line-height:1.3;list-style:none;">
    <span>{{ block.settings.tab_heading }}</span>
    <span style="font-size:22px;font-weight:300;">+</span>
  </summary>
  <div style="padding:0 0 20px;font-size:15px;line-height:1.7;">
    {{ block.settings.tab_content }}
  </div>
</details>

{% schema %}
{
  "name": "Product Tab",
  "tag": null,
  "settings": [
    {
      "type": "text",
      "id": "tab_heading",
      "label": "Tab heading",
      "default": "Tab Title"
    },
    {
      "type": "richtext",
      "id": "tab_content",
      "label": "Tab content",
      "default": "<p>Add your content here.</p>"
    }
  ],
  "presets": [
    {
      "name": "Product Tab"
    }
  ]
}
{% endschema %}
